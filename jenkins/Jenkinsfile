pipeline {
    agent { label 'rohit-agent-1' }

    environment {
        DOCKER_IMAGE = "portfolio-app"
        DOCKER_COMPOSE_FILE = "docker/docker-compose.yml"
        REPO_URL = "https://github.com/rohitrawat025/devops-aws-jenkins-docker-cicd-platform.git"
    }

    stages {
        stage('Cleanup') {
            steps {
                echo 'Cleaning up workspace...'
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                // Fixed: Using your actual repository URL and credentials ID from logs
                git branch: 'master', 
                    url: "${env.REPO_URL}",
                    credentialsId: '77a0a523-5d22-4db6-8793-bf409fa1d433'
            }
        }

        stage('Build & Test') {
            steps {
                echo 'Building Application...'
                // If you have a pom.xml, you might run: sh 'mvn clean package -DskipTests'
                sh 'ls -R' 
            }
        }

        stage('Docker Build') {
            steps {
                echo 'Building Docker Images...'
                sh "docker compose -f ${env.DOCKER_COMPOSE_FILE} build"
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying with Docker Compose...'
                sh "docker compose -f ${env.DOCKER_COMPOSE_FILE} up -d"
            }
        }

        stage('Verify') {
            steps {
                echo 'Verifying deployment...'
                sh 'docker ps'
                // Check if the container is responding on port 8080 or 80
                sh 'curl -I http://localhost || true'
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution finished.'
        }
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed. Checking logs...'
            sh "docker compose -f ${env.DOCKER_COMPOSE_FILE} logs || true"
        }
    }
}
