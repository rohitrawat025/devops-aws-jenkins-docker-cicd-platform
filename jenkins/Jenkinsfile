pipeline {

    agent { label 'rohit-agent-1' }

    triggers {
        githubPush()
    }

    environment {
        COMPOSE_FILE = "docker/docker-compose.yml"
        WORKSPACE_DIR = "/home/ubuntu/workspace/${JOB_NAME}"
    }

    stages {

        stage('Fix Workspace Permissions') {
            steps {
                sh '''
                echo "Fixing workspace permissions..."
                sudo chown -R ubuntu:ubuntu $WORKSPACE_DIR || true
                '''
            }
        }

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Verify Repository Structure') {
            steps {
                sh '''
                echo "Listing repository structure"
                ls -la
                ls -la docker
                '''
            }
        }

        stage('Prepare Nginx Config') {
            steps {
                sh '''
                echo "Preparing nginx configuration..."

                mkdir -p nginx/sites-enabled

                cp nginx/sites-available/nw-nginx.conf nginx/sites-enabled/

                echo "Nginx config prepared"

                ls -l nginx/sites-enabled
                '''
            }
        }

        stage('Docker Cleanup') {
            steps {
                sh '''
                echo "Stopping existing containers..."

                docker compose -f $COMPOSE_FILE down || true

                echo "Removing unused images..."

                docker system prune -f || true
                '''
            }
        }

        stage('Build Docker Images') {
            steps {
                sh '''
                echo "Building Docker images..."

                docker compose -f $COMPOSE_FILE build
                '''
            }
        }

        stage('Deploy Containers') {
            steps {
                sh '''
                echo "Starting containers..."

                docker compose -f $COMPOSE_FILE up -d
                '''
            }
        }

        stage('Wait For Application') {
            steps {
                sh '''
                echo "Waiting for Spring Boot to start..."

                sleep 20
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                echo "Running containers:"
                docker ps

                echo "Testing application..."

                curl -I http://localhost:81 || true
                '''
            }
        }

    }

    post {

        success {
            echo "Deployment successful!"

            sh '''
            echo "Application URL:"
            curl -s ifconfig.me
            '''
        }

        failure {
            echo "Pipeline failed!"
        }

    }

}
