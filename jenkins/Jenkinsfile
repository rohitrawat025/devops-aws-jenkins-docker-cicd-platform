pipeline {

agent { label 'rohit-agent-1' }

triggers {
githubPush()
}

environment {

COMPOSE_FILE="docker/docker-compose.yml"

}

stages {

stage('Checkout') {

steps {

git url: 'https://github.com/<username>/devops-cicd-portfolio-platform.git',
branch: 'main'

}

}

stage('Stop Containers') {

steps {

sh '''
docker compose -f $COMPOSE_FILE down || true
'''

}

}

stage('Build Containers') {

steps {

sh '''
docker compose -f $COMPOSE_FILE build
'''

}

}

stage('Start Containers') {

steps {

sh '''
docker compose -f $COMPOSE_FILE up -d
'''

}

}

stage('Configure Nginx') {

steps {

sh '''

docker exec portfolio-nginx mkdir -p /etc/nginx/sites-enabled

docker exec portfolio-nginx ln -sf \
/etc/nginx/sites-available/nw-nginx.conf \
/etc/nginx/sites-enabled/nw-nginx.conf

docker exec portfolio-nginx nginx -s reload

'''

}

}

stage('Verify Deployment') {

steps {

sh '''

docker ps

curl http://localhost

'''

}

}

}

}
