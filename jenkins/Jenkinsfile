pipeline {

    agent { label 'rohit-agent-1' }

    triggers {
        githubPush()
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'master',
                url: 'https://github.com/rohitrawat025/devops-aws-jenkins-docker-cicd-platform.git'
            }
        }

        stage('Prepare Nginx Config') {
            steps {
                sh '''
                mkdir -p nginx/sites-enabled

                cp nginx/sites-available/nw-nginx.conf nginx/sites-enabled/

                ls -l nginx/sites-enabled
                '''
            }
        }

        stage('Build Application') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker compose -f docker/docker-compose.yml build'
            }
        }

        stage('Deploy Containers') {
            steps {
                sh '''
                docker compose -f docker/docker-compose.yml down || true
                docker compose -f docker/docker-compose.yml up -d
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                docker ps
                curl http://localhost:81 || true
                '''
            }
        }

    }
}
