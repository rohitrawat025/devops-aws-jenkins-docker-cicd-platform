pipeline {

    agent any

    stages {

        stage('Cleanup') {
            steps {
                echo "Cleaning workspace..."
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                git credentialsId: 'github-token',
                url: 'https://github.com/rohitrawat025/devops-aws-jenkins-docker-cicd-platform.git',
                branch: 'master'
            }
        }

        stage('Build Application') {
            steps {
                echo "Building Spring Boot App..."
                sh 'ls -R'
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker Images..."
                sh 'docker compose -f docker/docker-compose.yml build'
            }
        }

        stage('Deploy Containers') {
            steps {
                echo "Starting Containers..."
                sh 'docker compose -f docker/docker-compose.yml up -d'
            }
        }

        stage('Configure Nginx') {
            steps {
                sh '''

                echo "Creating nginx directories..."

                docker exec portfolio-nginx mkdir -p /etc/nginx/sites-available
                docker exec portfolio-nginx mkdir -p /etc/nginx/sites-enabled

                echo "Ensuring nginx reads sites-enabled..."

                docker exec portfolio-nginx sh -c "
                grep -q 'sites-enabled' /etc/nginx/nginx.conf || \
                sed -i '/include \\/etc\\/nginx\\/conf.d\\/\\*.conf;/a include /etc/nginx/sites-enabled/*;' /etc/nginx/nginx.conf
                "

                echo "Enable site..."

                docker exec portfolio-nginx ln -sf \
                /etc/nginx/sites-available/nw-nginx.conf \
                /etc/nginx/sites-enabled/nw-nginx.conf

                echo "Reload nginx..."

                docker exec portfolio-nginx nginx -t
                docker exec portfolio-nginx nginx -s reload

                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                echo "Checking running containers..."
                sh 'docker ps'

                echo "Testing nginx..."
                sh 'curl -I http://localhost:81 || true'
            }
        }

    }

    post {

        success {
            echo "Deployment successful!"
        }

        failure {
            echo "Deployment failed. Checking logs..."

            sh 'docker compose -f docker/docker-compose.yml logs || true'
        }

    }
}
