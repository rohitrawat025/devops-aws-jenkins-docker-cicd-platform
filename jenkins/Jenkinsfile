pipeline {

    agent { label 'rohit-agent-1' }

    triggers {
        githubPush()
    }

    environment {
        COMPOSE_FILE = "docker/docker-compose.yml"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'master',
                url: 'https://github.com/rohitrawat025/devops-aws-jenkins-docker-cicd-platform.git'
            }
        }

        stage('Prepare Nginx Config') {
            steps {
                sh '''
                mkdir -p nginx/sites-enabled

                cp nginx/sites-available/nw-nginx.conf nginx/sites-enabled/

                echo "Nginx configuration prepared"

                ls -l nginx/sites-enabled
                '''
            }
        }

        stage('Build Docker Images') {
            steps {
                sh '''
                docker compose -f $COMPOSE_FILE build
                '''
            }
        }

        stage('Deploy Containers') {
            steps {
                sh '''
                docker compose -f $COMPOSE_FILE down || true
                docker compose -f $COMPOSE_FILE up -d
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                echo "Running containers:"
                docker ps

                echo "Testing application..."
                curl -I http://localhost:81 || true
                '''
            }
        }

    }

    post {

        success {
            echo "Deployment successful!"
        }

        failure {
            echo "Pipeline failed!"
        }

    }
}
